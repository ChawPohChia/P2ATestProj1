# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Asia/Singapore

# OpenAI (ChatGPT-compatible)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# X (Twitter) API v2 — Bearer token (Recent search)
X_BEARER_TOKEN=

# Query for recent search (Singapore + weather; adjust as needed)
X_SEARCH_QUERY=("Singapore" OR #Singapore OR SG) (weather OR haze OR rain OR NEA OR MSS) -is:retweet lang:en

# Ingestion
INGEST_MAX_RESULTS=50
INGEST_MAX_PAGES=2
INGEST_INTERVAL_MINUTES=60

# Retries (exponential backoff + jitter)
API_MAX_RETRIES=5
API_RETRY_BASE_SECONDS=1.0
